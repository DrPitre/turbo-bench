+
+/** Interrupt vectors as a struct.  */
+struct interrupt_vectors
+{
+  interrupt_t res0_handler;        /* 0x80 */
+  interrupt_t res1_handler;        /* 0x82 */
+  interrupt_t res2_handler;        /* 0x84 */
